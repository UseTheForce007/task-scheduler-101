{
  "version": 8,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with TSan + UBSan",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TS_ENABLE_TSAN": "ON",
        "TS_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build with optimisations, no sanitizers",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TS_ENABLE_TSAN": "OFF",
        "TS_ENABLE_ASAN": "OFF",
        "TS_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan",
      "description": "Debug build with ASan + UBSan (use for memory bugs)",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TS_ENABLE_TSAN": "OFF",
        "TS_ENABLE_ASAN": "ON",
        "TS_ENABLE_UBSAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    }
  ]
}
